{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "setup-env",
      "type": "shell",
      "command": "bash",
      "args": ["setup.sh"],
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Install Dependencies",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "pip", "install", "-r", "requirements.txt"],
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Python: Run Main Script",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["main.py"],
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "isBackground": false
    },
    {
      "label": "Python: Run Tests",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "pytest", "tests/", "-v", "-s"],
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": ["$pytest"]
    },
    {
      "label": "FastAPI: Start Server",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "uvicorn",
        "apps.api.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Application startup complete.*$",
          "endsPattern": "^.*Shutting down.*$"
        }
      }
    },
    {
      "label": "Node: Install Dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "cwd": "${workspaceFolder}/apps/web",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Node: Web Dev Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "cwd": "${workspaceFolder}/apps/web",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*Local:.*http.*$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*VITE.*ready in.*ms.*$",
          "endsPattern": "^.*$"
        }
      }
    },
    {
      "label": "Node: Build Web App",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "cwd": "${workspaceFolder}/apps/web",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Docker: Full Stack Up",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/dev/fullstack.sh"],
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Docker: Full Stack Down",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "cd infra/docker && docker compose -f docker-compose.job-tracker.yml down"
      ],
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Lint: Python (Ruff)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "ruff", "check", "."],
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": ["$ruff"]
    },
    {
      "label": "Format: Python (Black)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "black", ".", "--line-length=100"],
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Format: Web (Prettier)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "format"],
      "cwd": "${workspaceFolder}/apps/web",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
