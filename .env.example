# Job Copilot — Environment Variables Template
# Rename this file to .env and fill in your keys.

# ── Google Gemini API (Required for AI features) ──
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── France Travail API (CORE source — gratuit & illimité) ──
# Inscription 5 min : https://francetravail.io/
# Crée une appli avec scope "api_offresdemploiv2 o2dsoffre"
FT_CLIENT_ID=your_client_id_here
FT_CLIENT_SECRET=your_client_secret_here

# ── Adzuna API (complément — 1000 req/mois gratuites) ──
# Inscription : https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# Other configurations
DEBUG=False
